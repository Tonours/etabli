{
  "packages": [
    {
      "source": "npm:mitsupi",
      "extensions": [
        "!uv.ts",
        "-pi-extensions/go-to-bed.ts",
        "-pi-extensions/session-breakdown.ts"
      ]
    },
    "npm:checkpoint",
    "npm:pi-magic-docs",
    {
      "source": "npm:pi-hooks",
      "extensions": [
        "lsp/lsp.ts",
        "lsp/lsp-tool.ts"
      ],
      "skills": [],
      "prompts": [],
      "themes": []
    },
    "npm:pi-notify",
    {
      "source": "git:github.com/badlogic/pi-skills",
      "skills": [
        "brave-search",
        "youtube-transcript"
      ],
      "extensions": [],
      "prompts": [],
      "themes": []
    },
    {
      "source": "local:etabli-workflow",
      "extensions": [
        "fast-handoff.ts",
        "tilldone-ops-sync.ts",
        "review-plan-bridge.ts",
        "auto-validate.ts",
        "workflow-metrics.ts",
        "project-switcher.ts",
        "task-templates.ts",
        "auto-resume.ts",
        "scope-guard.ts",
        "pre-flight.ts",
        "smart-context.ts",
        "health-check.ts",
        "error-recovery.ts",
        "context-help.ts"
      ]
    }
  ],
  "lsp": {
    "hookMode": "agent_end"
  },
  "lastChangelogVersion": "0.64.0",
  "defaultProvider": "zai",
  "defaultModel": "glm-5.1",
  "theme": "catppuccin-mocha",
  "defaultThinkingLevel": "off",
  "subagents": {
    "scout": {
      "model": "kimi-coding/k2p5",
      "thinking": "high"
    },
    "worker": {
      "model": "openai-codex/gpt-5.4",
      "thinking": "high"
    },
    "reviewer": {
      "model": "github-copilot/claude-sonnet-4.6",
      "thinking": "high"
    }
  },
  "subagentAutomation": {
    "planLoop": {
      "enabled": true,
      "autoScout": true,
      "autoReviewer": true
    },
    "planImplement": {
      "enabled": true,
      "autoScout": true,
      "autoReviewer": true,
      "autoWorkerOnReady": true
    }
  },
  "editorPaddingX": 1,
  "hideThinkingBlock": true,
  "collapseChangelog": true,
  "quietStartup": true,
  "doubleEscapeAction": "tree"
}
