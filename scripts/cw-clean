#!/usr/bin/env bash

set -euo pipefail

resolve_script_dir() {
    local source_path="${BASH_SOURCE[0]}"
    local dir=""

    while [ -L "$source_path" ]; do
        dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
        source_path="$(readlink "$source_path")"
        [[ "$source_path" != /* ]] && source_path="${dir}/${source_path}"
    done

    cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
# shellcheck source=lib/worktree-common.sh
source "${SCRIPT_DIR}/lib/worktree-common.sh"
# shellcheck source=lib/cw-worktree-state.sh
source "${SCRIPT_DIR}/lib/cw-worktree-state.sh"
# shellcheck source=lib/cw-tmux.sh
source "${SCRIPT_DIR}/lib/cw-tmux.sh"

usage() {
    cat <<EOF
Usage: cw-clean [options] <repo|path>

Inspect and clean merged worktrees for a repository.

Default mode is dry-run. Use --yes to actually remove worktrees.

Options:
  -f, --force         Remove dirty worktrees too (passes --force to git worktree remove).
      --gone          Include clean worktrees whose upstream branch is gone.
      --no-fetch      Skip 'git fetch origin --prune'.
      --no-tmux       Do not close tmux windows pointing to removed worktrees.
  -n, --dry-run       Show what would be removed (default).
  -y, --yes           Apply removals without prompting.
  -h, --help          Show this help.

Examples:
  cw-clean api
  cw-clean api --gone
  cw-clean api --yes --force
EOF
}

DRY_RUN=true
FETCH=true
FORCE_REMOVE=false
INCLUDE_GONE=false
TMUX_CLEAN=true
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--force)
            FORCE_REMOVE=true
            shift
            ;;
        --gone)
            INCLUDE_GONE=true
            shift
            ;;
        --no-fetch)
            FETCH=false
            shift
            ;;
        --no-tmux)
            TMUX_CLEAN=false
            shift
            ;;
        -n|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -y|--yes)
            DRY_RUN=false
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                POSITIONAL_ARGS+=("$1")
                shift
            done
            break
            ;;
        -*)
            cw_die "unknown option: $1"
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

set -- "${POSITIONAL_ARGS[@]}"

[ $# -eq 1 ] || {
    usage >&2
    exit 1
}

cw_require_bin git

REPO_PATH="$(cw_resolve_repo_path "$1" 2>/dev/null || true)"
[ -n "$REPO_PATH" ] || cw_die "repo not found: $1"

REPO_NAME="$(basename "$REPO_PATH")"
BASE_REF="$(cw_resolve_base_ref "$REPO_PATH" "")"
BASE_CHECK_REF="$(cw_preferred_base_ref "$REPO_PATH" "$BASE_REF")"
BASE_LABEL="${BASE_CHECK_REF#origin/}"

if [ "$FETCH" = true ]; then
    cw_info "Fetching ${REPO_NAME}..."
    cw_fetch_origin "$REPO_PATH"
fi

declare -a RECORD_PATHS=()
declare -a RECORD_BRANCHES=()
declare -a RECORD_REASONS=()
declare -a RECORD_DIRTY=()
declare -a RECORD_ACTIONS=()

current_path=""
current_branch=""
current_prunable="no"

append_record() {
    local path="$1"
    local branch="$2"
    local reason="$3"
    local dirty="$4"
    local action="$5"

    RECORD_PATHS+=("$path")
    RECORD_BRANCHES+=("$branch")
    RECORD_REASONS+=("$reason")
    RECORD_DIRTY+=("$dirty")
    RECORD_ACTIONS+=("$action")
}

evaluate_record() {
    local path="$1"
    local branch="$2"
    local prunable="$3"
    local dirty="no"
    local upstream=""
    local reason="keep"
    local action="keep"

    [ -n "$path" ] || return 0
    [ "$path" != "$REPO_PATH" ] || return 0

    if [ "$prunable" = "yes" ]; then
        append_record "$path" "${branch:--}" "stale" "n/a" "prune"
        return 0
    fi

    if [ -z "$branch" ]; then
        append_record "$path" "-" "detached" "n/a" "skip"
        return 0
    fi

    if cw_worktree_is_dirty "$path"; then
        dirty="yes"
    fi

    if cw_branch_is_merged_into "$REPO_PATH" "$branch" "$BASE_CHECK_REF"; then
        reason="merged"
        action="remove"
    else
        upstream="$(git -C "$path" for-each-ref --format='%(upstream:short)' "refs/heads/${branch}" | head -n 1)"
        if [ -n "$upstream" ] && ! git -C "$REPO_PATH" show-ref --verify --quiet "refs/remotes/${upstream}"; then
            reason="gone-upstream"
            if [ "$INCLUDE_GONE" = true ]; then
                action="remove"
            else
                action="keep"
            fi
        fi
    fi

    if [ "$action" = "remove" ] && [ "$dirty" = "yes" ] && [ "$FORCE_REMOVE" = false ]; then
        action="skip-dirty"
    fi

    append_record "$path" "$branch" "$reason" "$dirty" "$action"
}

while IFS=$'\t' read -r current_path current_branch current_prunable; do
    evaluate_record "$current_path" "$current_branch" "$current_prunable"
done < <(cw_worktree_records "$REPO_PATH")

printf "Repository: %s\n" "$REPO_PATH"
printf "Base ref:   %s\n" "$BASE_REF"
printf "Merge ref:  %s\n\n" "$BASE_CHECK_REF"

if [ "${#RECORD_PATHS[@]}" -eq 0 ]; then
    printf "No secondary worktrees found.\n"
    exit 0
fi

printf "%-12s %-12s %-8s %s\n" "action" "reason" "dirty" "branch -> path"
printf "%-12s %-12s %-8s %s\n" "------------" "------------" "--------" "-------------"

REMOVE_COUNT=0
PRUNE_COUNT=0
for i in "${!RECORD_PATHS[@]}"; do
    printf "%-12s %-12s %-8s %s -> %s\n" \
        "${RECORD_ACTIONS[$i]}" \
        "${RECORD_REASONS[$i]}" \
        "${RECORD_DIRTY[$i]}" \
        "${RECORD_BRANCHES[$i]}" \
        "${RECORD_PATHS[$i]}"

    if [ "${RECORD_ACTIONS[$i]}" = "remove" ]; then
        REMOVE_COUNT=$((REMOVE_COUNT + 1))
    elif [ "${RECORD_ACTIONS[$i]}" = "prune" ]; then
        PRUNE_COUNT=$((PRUNE_COUNT + 1))
    fi
done

printf "\n"

if [ "$DRY_RUN" = true ]; then
    if [ "$REMOVE_COUNT" -eq 0 ]; then
        if [ "$PRUNE_COUNT" -gt 0 ]; then
            printf "Dry-run complete. %s stale worktree entrie(s) would be pruned.\n" "$PRUNE_COUNT"
        else
            printf "Dry-run complete. Nothing removable with the current flags.\n"
        fi
    else
        printf "Dry-run complete. %s worktree(s) would be removed.\n" "$REMOVE_COUNT"
        printf "Apply with: cw-clean %s --yes" "$REPO_NAME"
        [ "$INCLUDE_GONE" = true ] && printf " --gone"
        [ "$FORCE_REMOVE" = true ] && printf " --force"
        [ "$TMUX_CLEAN" = false ] && printf " --no-tmux"
        [ "$FETCH" = false ] && printf " --no-fetch"
        printf "\n"
    fi
    exit 0
fi

if [ "$REMOVE_COUNT" -eq 0 ] && [ "$PRUNE_COUNT" -eq 0 ]; then
    printf "Nothing to remove.\n"
    exit 0
fi

for i in "${!RECORD_PATHS[@]}"; do
    [ "${RECORD_ACTIONS[$i]}" = "remove" ] || continue

    target_path="${RECORD_PATHS[$i]}"
    target_branch="${RECORD_BRANCHES[$i]}"
    target_reason="${RECORD_REASONS[$i]}"

    cw_info "Removing ${target_branch} (${target_reason})"
    [ "$TMUX_CLEAN" = true ] && cw_close_tmux_windows_for_path "$target_path"

    if [ "$FORCE_REMOVE" = true ]; then
        git -C "$REPO_PATH" worktree remove "$target_path" --force
    else
        git -C "$REPO_PATH" worktree remove "$target_path"
    fi

    if [ "$target_reason" = "merged" ] && cw_local_branch_exists "$REPO_PATH" "$target_branch"; then
        git -C "$REPO_PATH" branch -d "$target_branch" >/dev/null 2>&1 || \
            cw_warn "could not delete local branch '${target_branch}'"
    fi
done

if [ "$PRUNE_COUNT" -gt 0 ] || [ "$REMOVE_COUNT" -gt 0 ]; then
    git -C "$REPO_PATH" worktree prune
fi

printf "\nCleanup complete.\n"
printf "Merged into: %s\n" "$BASE_LABEL"
