#!/bin/bash

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
FONT="JetBrainsMono Nerd Font"
WORKSPACE_LIMIT=5
SPACE_HELPER="$HOME/.local/bin/yabai-space-local.sh"

add_spaces_for_display() {
    local display="$1"
    local slot=1
    local -a spaces

    while IFS= read -r space_id; do
        spaces+=("$space_id")
    done < <(yabai -m query --displays --display "$display" 2>/dev/null | jq -r --argjson limit "$WORKSPACE_LIMIT" '.spaces[:$limit][]')

    for space_id in "${spaces[@]}"; do
        sketchybar --add space "space.$space_id" left \
            --set "space.$space_id" \
                associated_space="$space_id" \
                display="$display" \
                icon.drawing=off \
                label="$slot" \
                label.font="$FONT:Bold:11.0" \
                label.color="$OVERLAY0" \
                label.padding_left=7 \
                label.padding_right=7 \
                background.color="$CRUST" \
                background.corner_radius=0 \
                background.height=28 \
                script="$PLUGIN_DIR/space.sh" \
                click_script="$SPACE_HELPER focus $slot $display"

        slot=$((slot + 1))
    done
}

# ============================================================================
# BAR
# ============================================================================
sketchybar --bar \
    position=top \
    height=30 \
    color="$BAR_COLOR" \
    border_width=0 \
    shadow=off \
    blur_radius=0 \
    corner_radius=0 \
    y_offset=0 \
    margin=0 \
    padding_left=10 \
    padding_right=10 \
    notch_width=0 \
    topmost=on

# ============================================================================
# DEFAULTS
# ============================================================================
sketchybar --default \
    icon.font="$FONT:Bold:12.0" \
    icon.color="$TEXT" \
    label.font="$FONT:Regular:11.0" \
    label.color="$TEXT" \
    background.color="$BAR_COLOR" \
    background.height=28 \
    padding_left=5 \
    padding_right=5

# ============================================================================
# LEFT: Workspaces
# ============================================================================
add_spaces_for_display 1
add_spaces_for_display 2

sketchybar --add item front_app left \
    --set front_app \
        icon.drawing=off \
        label.font="$FONT:Bold:11.0" \
        label.color="$SUBTEXT1" \
        label.padding_left=10 \
        script="$PLUGIN_DIR/front_app.sh" \
    --subscribe front_app front_app_switched

# ============================================================================
# CENTER: Clock
# ============================================================================
sketchybar --add item clock center \
    --set clock \
        icon="$ICON_CLOCK" \
        icon.color="$ACCENT_COLOR" \
        label.font="$FONT:Regular:11.0" \
        label.color="$TEXT" \
        update_freq=60 \
        script="$PLUGIN_DIR/clock.sh"

# ============================================================================
# RIGHT: System info
# ============================================================================
sketchybar --add item tailscale right \
    --set tailscale \
        icon.font="$FONT:Bold:14.0" \
        label.drawing=off \
        update_freq=180 \
        script="$PLUGIN_DIR/tailscale.sh" \
        click_script="open -a Tailscale"

sketchybar --add item wifi right \
    --set wifi \
        icon.font="$FONT:Bold:14.0" \
        label.drawing=off \
        update_freq=120 \
        script="$PLUGIN_DIR/wifi.sh"

sketchybar --add item volume right \
    --set volume \
        icon.font="$FONT:Bold:14.0" \
        label.drawing=off \
        script="$PLUGIN_DIR/volume.sh" \
    --subscribe volume volume_change

sketchybar --add item cpu right \
    --set cpu \
        icon.font="$FONT:Bold:14.0" \
        label.drawing=off \
        update_freq=120 \
        script="$PLUGIN_DIR/cpu.sh"

sketchybar --add item battery right \
    --set battery \
        icon.font="$FONT:Bold:14.0" \
        label.drawing=off \
        update_freq=120 \
        script="$PLUGIN_DIR/battery.sh" \
    --subscribe battery power_source_change system_woke

# ============================================================================
# INIT
# ============================================================================
sketchybar --update
